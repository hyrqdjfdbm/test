<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>项目状态信息录入</title>
    <!-- Element Plus 样式 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/element-plus@2.4.4/dist/index.css">
    <!-- Vue 3 -->
    <script src="https://cdn.jsdelivr.net/npm/vue@3.3.4/dist/vue.global.min.js"></script>
    <!-- Element Plus 组件 -->
    <script src="https://cdn.jsdelivr.net/npm/element-plus@2.4.4/dist/index.full.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: Arial, sans-serif;
            background-color: #f5f7fa;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }
        
        .container {
            width: 100%;
            max-width: 800px;
        }
        
        .main-btn {
            width: 100%;
            padding: 16px;
            font-size: 18px;
            background: linear-gradient(135deg, #409EFF 0%, #67C23A 100%);
            border: none;
            border-radius: 8px;
            color: white;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        
        .main-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(64, 158, 255, 0.3);
        }
        
        /* 弹窗样式 */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }
        
        .modal-overlay.show {
            display: flex;
        }
        
        .modal-container {
            background-color: white;
            border-radius: 12px;
            width: 90%;
            max-width: 700px;
            max-height: 90vh;
            overflow-y: auto;
            animation: modalFadeIn 0.3s ease;
        }
        
        @keyframes modalFadeIn {
            from {
                opacity: 0;
                transform: scale(0.95);
            }
            to {
                opacity: 1;
                transform: scale(1);
            }
        }
        
        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px;
            border-bottom: 1px solid #eee;
            background-color: #409EFF;
            color: white;
            border-radius: 12px 12px 0 0;
        }
        
        .modal-title {
            font-size: 18px;
            font-weight: bold;
        }
        
        .modal-close {
            cursor: pointer;
            font-size: 24px;
            line-height: 1;
            opacity: 0.8;
            transition: opacity 0.2s;
        }
        
        .modal-close:hover {
            opacity: 1;
        }
        
        .modal-body {
            padding: 20px;
        }
        
        .form-item {
            margin-bottom: 20px;
        }
        
        .form-label {
            display: block;
            font-weight: bold;
            color: #333;
            margin-bottom: 8px;
            font-size: 14px;
        }
        
        .form-input {
            width: 100%;
            padding: 12px;
            border: 2px solid #e4e7ed;
            border-radius: 6px;
            font-size: 14px;
            transition: border-color 0.2s;
            resize: vertical;
            min-height: 80px;
        }
        
        .form-input:focus {
            outline: none;
            border-color: #409EFF;
            box-shadow: 0 0 0 2px rgba(64, 158, 255, 0.2);
        }
        
        .form-input::placeholder {
            color: #909399;
            font-style: italic;
        }
        
        /* 预览区域 */
        .preview-section {
            margin-top: 30px;
            padding: 20px;
            background-color: #f8fafc;
            border-radius: 8px;
            border-left: 4px solid #409EFF;
        }
        
        .preview-title {
            font-weight: bold;
            color: #409EFF;
            margin-bottom: 15px;
            font-size: 16px;
        }
        
        .preview-content {
            font-size: 14px;
            line-height: 1.8;
            color: #333;
            white-space: pre-wrap;
            word-break: break-all;
        }
        
        .preview-content:empty {
            color: #909399;
            font-style: italic;
        }
        
        /* 按钮区域 */
        .modal-footer {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            padding: 20px;
            border-top: 1px solid #eee;
            background-color: #fafafa;
            border-radius: 0 0 12px 12px;
        }
        
        .btn {
            padding: 10px 24px;
            border: none;
            border-radius: 6px;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s;
        }
        
        .btn-primary {
            background-color: #409EFF;
            color: white;
        }
        
        .btn-primary:hover {
            background-color: #66b1ff;
        }
        
        .btn-secondary {
            background-color: #f5f7fa;
            color: #606266;
        }
        
        .btn-secondary:hover {
            background-color: #e4e7ed;
        }
        
        /* 响应式设计 */
        @media (max-width: 768px) {
            .modal-container {
                width: 95%;
                margin: 10px;
            }
            
            .modal-body {
                padding: 15px;
            }
            
            .modal-footer {
                flex-direction: column;
            }
            
            .btn {
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <button class="main-btn" onclick="openModal()">录入项目状态信息</button>
    </div>
    
    <!-- 弹窗 -->
    <div id="modal" class="modal-overlay">
        <div class="modal-container">
            <div class="modal-header">
                <div class="modal-title">项目状态信息录入</div>
                <span class="modal-close" onclick="closeModal()">&times;</span>
            </div>
            <div class="modal-body">
                <!-- 表单 -->
                <div class="form-item">
                    <label class="form-label">问题类型：</label>
                    <select 
                        class="form-input" 
                        id="problemType"
                        onchange="handleProblemTypeChange()"
                        style="min-height: auto;"
                    >
                        <option value="搬林手续">搬林手续</option>
                        <option value="建设主体履职不到位">建设主体履职不到位</option>
                        <option value="市级审批">市级审批</option>
                        <option value="属地动迁腾地不力">属地动迁腾地不力</option>
                        <option value="用地指标">用地指标</option>
                        <option value="转批滞后">转批滞后</option>
                        <option value="方案问题">方案问题</option>
                        <option value="企业端问题">企业端问题</option>
                        <option value="资金问题">资金问题</option>
                        <option value="土地与征收问题">土地与征收问题</option>
                        <option value="其他">其他</option>
                    </select>
                </div>
                
                <div class="form-item" id="otherInput" style="display: none;">
                    <label class="form-label">请填写其他问题类型：</label>
                    <input 
                        type="text" 
                        class="form-input" 
                        id="otherType"
                        placeholder="请输入其他问题类型"
                        oninput="updatePreview()"
                        style="min-height: auto;"
                    >
                </div>
                
                <div class="form-item">
                    <label class="form-label">1、当前项目概况：</label>
                    <textarea 
                        class="form-input" 
                        id="projectStatus"
                        placeholder="一句话说明项目处于什么阶段：拿地暂缓/方案报批中/已开工但停工/待开工等"
                        oninput="updatePreview()"
                    ></textarea>
                </div>
                
                <div class="form-item">
                    <label class="form-label">2、当前主要卡点：</label>
                    <textarea 
                        class="form-input" 
                        id="projectBlocker"
                        placeholder="具体描述影响推进的障碍（如：等待市级评估、农户诉讼未判决、资金未到位、并购谈判未完成、电力管线未接通、交警审批未通过等）"
                        oninput="updatePreview()"
                    ></textarea>
                </div>
                
                <div class="form-item">
                    <label class="form-label">3、已完成的报审事项：</label>
                    <textarea 
                        class="form-input" 
                        id="completedApprovals"
                        placeholder="按时间列出已报审的文件名称、报送部门、报送时间（如：2026年X月X日向XX局报送概念方案）"
                        oninput="updatePreview()"
                    ></textarea>
                </div>
                
                <div class="form-item">
                    <label class="form-label">4、审批/主管部门回复：</label>
                    <textarea 
                        class="form-input" 
                        id="deptResponse"
                        placeholder="明确回复部门、回复时间、回复结论（如：xx部门回复原则同意但深度不足；已受理待评估；要求补充XX材料；尚未答复等）"
                        oninput="updatePreview()"
                    ></textarea>
                </div>
                
                <div class="form-item">
                    <label class="form-label">5、下一步计划及预计时间：</label>
                    <textarea 
                        class="form-input" 
                        id="nextPlan"
                        placeholder="明确下一步动作和关键时间节点（如：5月初再次报批，争取二季度挂牌；10月开工；待资金到位后复工等）"
                        oninput="updatePreview()"
                    ></textarea>
                </div>
                
                <!-- 实时预览 -->
                <div class="preview-section">
                    <div class="preview-title">📋 内容预览</div>
                    <div class="preview-content" id="previewContent">
                        请填写上方表单内容，预览将自动更新...
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeModal()">取消</button>
                <button class="btn btn-primary" onclick="submitForm()">提交</button>
            </div>
        </div>
    </div>
    
    <script>
        // 打开弹窗
        function openModal() {
            document.getElementById('modal').classList.add('show');
            // 清空表单
            document.getElementById('projectStatus').value = '';
            document.getElementById('projectBlocker').value = '';
            document.getElementById('completedApprovals').value = '';
            document.getElementById('deptResponse').value = '';
            updatePreview();
        }
        
        // 关闭弹窗
        function closeModal() {
            document.getElementById('modal').classList.remove('show');
        }
        
        // 处理问题类型变化
        function handleProblemTypeChange() {
            const select = document.getElementById('problemType');
            const otherInput = document.getElementById('otherInput');
            if (select.value === '其他') {
                otherInput.style.display = 'block';
            } else {
                otherInput.style.display = 'none';
                document.getElementById('otherType').value = '';
            }
            updatePreview();
        }
        
        // 更新预览内容
        function updatePreview() {
            // 获取问题类型
            const problemTypeSelect = document.getElementById('problemType');
            let problemType = problemTypeSelect.value;
            if (problemType === '其他') {
                problemType = document.getElementById('otherType').value || '其他问题类型';
            }
            
            const status = document.getElementById('projectStatus').value || '项目概况';
            const blocker = document.getElementById('projectBlocker').value || '当前主要卡点';
            const approvals = document.getElementById('completedApprovals').value || '已完成的报审事项';
            const response = document.getElementById('deptResponse').value || '审批/主管部门回复';
            const nextPlan = document.getElementById('nextPlan').value || '下一步计划及预计时间';
            
            const preview = `<u>${problemType}</u>：项目当前处于<u>${status}</u>阶段，卡点为 <u>${blocker}</u> ，<u>${approvals}</u>，<u>${response}</u>，下一步工作计划为<u>${nextPlan}</u>`;
            
            document.getElementById('previewContent').innerHTML = preview;
        }
        
        // 提交表单
        function submitForm() {
            const status = document.getElementById('projectStatus').value;
            const blocker = document.getElementById('projectBlocker').value;
            const approvals = document.getElementById('completedApprovals').value;
            const response = document.getElementById('deptResponse').value;
            
            // 简单验证
            if (!status || !blocker) {
                alert('请至少填写项目概况和主要卡点');
                return;
            }
            
            // 显示成功提示
            alert('提交成功！\n\n项目当前处于' + status + '\n卡点为' + blocker);
            
            // 关闭弹窗
            closeModal();
        }
        
        // 点击弹窗外部关闭
        document.getElementById('modal').addEventListener('click', function(e) {
            if (e.target === this) {
                closeModal();
            }
        });
    </script>
</body>
</html>
